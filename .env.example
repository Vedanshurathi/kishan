.env.example
# API Keys Configuration
# Rename this file to .env and add your API keys

# Weather API - Get free key from https://openweathermap.org
OPENWEATHER_API_KEY=your_openweather_api_key_here

# News API - Get free key from https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# Agri Market API (optional)
AGMARKNET_API_KEY=your_agmarknet_api_key_here

# Auto update data every hour
AUTO_UPDATE=false

# Server port
PORT=3000